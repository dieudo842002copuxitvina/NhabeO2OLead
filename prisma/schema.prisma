generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Profile {
  id         String     @id @db.Uuid
  full_name  String?
  phone      String?
  avatar_url String?
  updated_at DateTime?  @default(now()) @db.Timestamptz(6)
  dealer_id  String?    @db.Uuid
  dealers    Dealer?    @relation(fields: [dealer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users      @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_roles UserRole[]

  @@map("profiles")
  @@schema("public")
}

model UserRole {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  role       String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  profiles   Profile?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, role])
  @@map("user_roles")
  @@schema("public")
}

model Dealer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  phone      String?
  address    String?
  province   String?
  district   String?
  latitude   Float?
  longitude  Float?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  leads      Leads[]
  profiles   Profile[]

  @@map("dealers")
  @@schema("public")
}

model Leads {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_name      String?
  customer_phone     String
  province           String?
  district           String?
  crop_type          String?
  area_m2            Decimal? @db.Decimal
  calculator_data    Json     @default("{}")
  assigned_dealer_id String?  @db.Uuid
  status             String   @default("new")
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  distance_km        Float?
  latitude           Float?
  longitude          Float?
  dealers            Dealer?  @relation(fields: [assigned_dealer_id], references: [id], onUpdate: NoAction)

  @@map("leads")
  @@schema("public")
}

